 browser/actors/NamecoinParent.sys.mjs                    |  1 +
 browser/actors/NamecoinChild.sys.mjs                     |  1 +
 browser/components/BrowserGlue.sys.mjs                   | 17 +++++++++
 12 files changed, 53 insertions(+)
 create mode 120000 browser/components/about/content/aboutNamecoin.js
