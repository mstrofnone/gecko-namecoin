diff --git a/browser/actors/NamecoinParent.sys.mjs b/browser/actors/NamecoinParent.sys.mjs
new file mode 120000
index 0000000000..abcdef9012
--- /dev/null
+++ b/browser/actors/NamecoinParent.sys.mjs
@@ -0,0 +1 @@
+# Copy src/about-namecoin/NamecoinParent.sys.mjs here

diff --git a/browser/actors/NamecoinChild.sys.mjs b/browser/actors/NamecoinChild.sys.mjs
new file mode 120000
index 0000000000..abcdef3456
--- /dev/null
+++ b/browser/actors/NamecoinChild.sys.mjs
@@ -0,0 +1 @@
+# Copy src/about-namecoin/NamecoinChild.sys.mjs here

--- a/browser/components/BrowserGlue.sys.mjs
+++ b/browser/components/BrowserGlue.sys.mjs
@@ -XXX,6 +XXX,23 @@ const JSWINDOWACTORS = {
+
+  // ---------------------------------------------------------------------------
+  // Namecoin — about:namecoin diagnostic page IPC actors
+  // ---------------------------------------------------------------------------
+  // NamecoinParent runs in the chrome (parent) process and calls into the
+  // nsINamecoinResolver XPCOM service.  NamecoinChild runs in the content
+  // process and is used by aboutNamecoin.js to request data over IPC.
+  Namecoin: {
+    parent: {
+      esModuleURI: "resource:///actors/NamecoinParent.sys.mjs",
+    },
+    child: {
+      esModuleURI: "resource:///actors/NamecoinChild.sys.mjs",
+    },
+    matches: ["about:namecoin"],
+  },
+
 };
 
 // ... rest of BrowserGlue
