 });
 
 // ... existing code ...
@@ -1200,6 +1206,62 @@ export class UrlbarInput {
      */
     _updateIdentityIndicator(uri) {
       // ... existing identity indicator logic ...
+
+      // =====================================================================
+      // Namecoin .bit domain security indicator
+      // =====================================================================
+      // After the standard identity indicator logic, override for .bit domains.
+      // The Namecoin security state is determined by nsNamecoinResolver's DANE
+      // validation result, stored per-tab in the browser's securityUI.
+
+      if (uri && uri.host && uri.host.endsWith(".bit")) {
+        const nmcState = lazy.UrlbarNamecoinSecurity.getStateForBrowser(
+          this.window.gBrowser.selectedBrowser
+        );
+
+        const identityIcon = this.document.getElementById("identity-icon");
+        const identityBox = this.document.getElementById("identity-box");
+
+        // Remove any previous Namecoin classes
+        identityBox.classList.remove(
+          "nmc-secure",
+          "nmc-warning",
+          "nmc-error"
+        );
+
+        switch (nmcState.level) {
+          case "secure":
+            // DANE-TLSA validated: teal/green lock
+            identityBox.classList.add("nmc-secure");
+            identityIcon.setAttribute(
+              "data-l10n-id",
+              "urlbar-namecoin-secure-tooltip"
+            );
+            break;
+
+          case "warning":
+            // HTTP-only or missing TLSA: yellow/amber
+            identityBox.classList.add("nmc-warning");
+            identityIcon.setAttribute(
+              "data-l10n-id",
+              "urlbar-namecoin-warning-tooltip"
+            );
+            break;
+
+          case "error":
+            // TLSA validation failed: red
+            identityBox.classList.add("nmc-error");
+            identityIcon.setAttribute(
+              "data-l10n-id",
+              "urlbar-namecoin-error-tooltip"
+            );
+            break;
+
+          default:
+            // .bit domain but no DANE info (resolver not available, etc.)
+            // Fall through to standard indicator — don't override.
+            break;
+        }
+
+        // Update the identity popup panel text for .bit domains
+        if (nmcState.level !== "none") {
+          this._setNamecoinIdentityPopup(nmcState);
+        }
+      }
     }
 
+    /**
+     * Populate the identity popup panel with Namecoin-specific info.
+     *
+     * Shows: trust source (blockchain), block height, DANE status,
+     * and a link to the namecha.in block explorer for the name TX.
+     */
+    _setNamecoinIdentityPopup(nmcState) {
+      const host = this.window.gBrowser.selectedBrowser.currentURI?.host;
+      if (!host) return;
+
+      // REAL IMPL: Update the identity popup panel elements:
+      // document.getElementById("identity-popup-namecoin-title")
