 browser/themes/shared/urlbar/identity-block.css         | 75 ++++++++++++++
 browser/themes/shared/urlbar/urlbar.css                 |  4 ++++
 browser/components/urlbar/UrlbarNamecoinSecurity.sys.mjs| 95 +++++++++++++++++
 4 files changed, 236 insertions(+)
