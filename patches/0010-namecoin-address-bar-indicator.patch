--- /dev/null
+++ b/browser/components/urlbar/UrlbarNamecoinSecurity.sys.mjs
@@ -0,0 +1,95 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/**
+ * UrlbarNamecoinSecurity — reads the Namecoin DANE validation state
+ * for a given browser tab and returns a security level for the URL bar.
+ *
+ * Security levels:
+ *   "secure"  — DANE-TLSA record exists and certificate matches
+ *   "warning" — .bit domain loaded over HTTP, or no TLSA record found
+ *   "error"   — TLSA record exists but certificate does NOT match
+ *   "none"    — not a .bit domain or resolver unavailable
+ */
+
+export const UrlbarNamecoinSecurity = {
+  /**
+   * Get the Namecoin security state for the given browser element.
+   *
+   * @param {XULBrowserElement} browser - The browser tab to check.
+   * @returns {{ level: string, blockHeight: number|null, txHash: string|null,
+   *             expiryBlock: number|null, tlsaUsage: number|null }}
+   */
+  getStateForBrowser(browser) {
+    const uri = browser?.currentURI;
+    if (!uri || !uri.host || !uri.host.endsWith(".bit")) {
+      return { level: "none" };
+    }
+
+    // REAL IMPL: Read the security state from the tab's securityUI or from
+    // nsNamecoinResolver's per-host cache. The resolver stores the DANE
+    // validation result alongside the DNS resolution result.
+    //
+    // const secInfo = browser.securityUI?.secInfo;
+    // if (secInfo?.namecoinDANEState) {
+    //   return {
+    //     level: secInfo.namecoinDANEState.validated ? "secure" :
+    //            secInfo.namecoinDANEState.mismatch ? "error" : "warning",
+    //     blockHeight: secInfo.namecoinDANEState.blockHeight,
+    //     txHash: secInfo.namecoinDANEState.txHash,
+    //     expiryBlock: secInfo.namecoinDANEState.expiryBlock,
+    //     tlsaUsage: secInfo.namecoinDANEState.tlsaUsage,
+    //   };
+    // }
+
+    // Check if the connection is HTTPS
+    const isHttps = uri.scheme === "https";
+
+    // REAL IMPL: Query nsNamecoinResolver for DANE state
+    // For now, determine state based on scheme:
+    //   HTTPS .bit → assume DANE validated (prototype)
+    //   HTTP .bit  → warning
+    if (isHttps) {
+      return {
+        level: "secure",
+        blockHeight: null,
+        txHash: null,
+        expiryBlock: null,
+        tlsaUsage: 3,
+      };
+    }
+
+    return {
+      level: "warning",
+      blockHeight: null,
+      txHash: null,
+      expiryBlock: null,
+      tlsaUsage: null,
+    };
+  },
+};

--- a/browser/themes/shared/urlbar/identity-block.css
+++ b/browser/themes/shared/urlbar/identity-block.css
@@ -120,6 +120,81 @@
   fill: var(--urlbar-identity-icon-color-verified, #058b00);
 }
 
+/* =========================================================================
+ * Namecoin .bit domain security indicators
+ *
+ * Three states matching the DANE validation result from nsNamecoinResolver.
+ * Uses the Proton design language with Namecoin-specific accent colors.
+ * ========================================================================= */
+
+/* --- nmc-secure: DANE-TLSA validated (teal/green lock) --- */
+#identity-box.nmc-secure {
+  --urlbar-box-bgcolor: color-mix(in srgb, #00a78e 12%, transparent);
+  --urlbar-box-hover-bgcolor: color-mix(in srgb, #00a78e 18%, transparent);
+}
+
+#identity-box.nmc-secure #identity-icon {
+  /* Teal lock icon — distinct from standard EV green */
+  fill: #00a78e;
+  list-style-image: url("chrome://global/skin/icons/security.svg");
+}
+
+#identity-box.nmc-secure .identity-icon-label {
+  display: inline;
+  color: #00a78e;
+  font-weight: 600;
+}
+
+@media (prefers-color-scheme: dark) {
+  #identity-box.nmc-secure {
+    --urlbar-box-bgcolor: color-mix(in srgb, #00d4b4 15%, transparent);
+    --urlbar-box-hover-bgcolor: color-mix(in srgb, #00d4b4 22%, transparent);
+  }
+  #identity-box.nmc-secure #identity-icon {
+    fill: #00d4b4;
+  }
+  #identity-box.nmc-secure .identity-icon-label {
+    color: #00d4b4;
+  }
+}
+
+/* --- nmc-warning: HTTP-only or no TLSA record (yellow/amber) --- */
+#identity-box.nmc-warning {
+  --urlbar-box-bgcolor: color-mix(in srgb, #c27400 10%, transparent);
+  --urlbar-box-hover-bgcolor: color-mix(in srgb, #c27400 16%, transparent);
+}
+
+#identity-box.nmc-warning #identity-icon {
+  fill: #c27400;
+  list-style-image: url("chrome://global/skin/icons/warning.svg");
+}
+
+@media (prefers-color-scheme: dark) {
+  #identity-box.nmc-warning {
+    --urlbar-box-bgcolor: color-mix(in srgb, #ffbd4f 12%, transparent);
+    --urlbar-box-hover-bgcolor: color-mix(in srgb, #ffbd4f 18%, transparent);
+  }
+  #identity-box.nmc-warning #identity-icon {
+    fill: #ffbd4f;
+  }
+}
+
+/* --- nmc-error: TLSA validation failed (red) --- */
+#identity-box.nmc-error {
+  --urlbar-box-bgcolor: color-mix(in srgb, #d70022 10%, transparent);
+  --urlbar-box-hover-bgcolor: color-mix(in srgb, #d70022 16%, transparent);
+}
+
+#identity-box.nmc-error #identity-icon {
+  fill: #d70022;
+  list-style-image: url("chrome://global/skin/icons/security-broken.svg");
+}
+
+@media (prefers-color-scheme: dark) {
+  #identity-box.nmc-error {
+    --urlbar-box-bgcolor: color-mix(in srgb, #ff6a75 12%, transparent);
+    --urlbar-box-hover-bgcolor: color-mix(in srgb, #ff6a75 18%, transparent);
+  }
+  #identity-box.nmc-error #identity-icon {
+    fill: #ff6a75;
+  }
+}
+
 /* Identity popup panel text */
 #identity-popup-content-supplemental {

