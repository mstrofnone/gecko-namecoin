diff --git a/browser/components/preferences/privacy.js b/browser/components/preferences/privacy.js
index 00000007..00000008 100644
--- a/browser/components/preferences/privacy.js
+++ b/browser/components/preferences/privacy.js
@@ -2800,12 +2800,53 @@
+  // =========================================================================
+  // Namecoin (.bit) Settings -- Phase 5 enablement gating
+  // =========================================================================
+
+  /**
+   * Import the NamecoinFeature module lazily to avoid pulling it into
+   * every Privacy pane load when the feature is compiled out.
+   */
+  get _namecoinFeature() {
+    if (!this.__namecoinFeature) {
+      const { NamecoinFeature } = ChromeUtils.importESModule(
+        "resource://gre/modules/NamecoinFeature.sys.mjs"
+      );
+      this.__namecoinFeature = NamecoinFeature;
+    }
+    return this.__namecoinFeature;
+  },
+
   /**
    * Initialize the Namecoin settings section.
    * Called from gPrivacyPane.init().
+   *
+   * Phase 5 gating:
+   *   - Nightly builds: always show (developers need access).
+   *   - Beta/Release: only show when network.namecoin.settings_visible is true
+   *     (controlled by Normandy experiment rollout).
    */
   initNamecoinSettings() {
+    const feature = this._namecoinFeature;
+
+    // Determine visibility based on stage.
+    const shouldShow =
+      feature.isNightlyBuild() || feature.isSettingsVisible();
+
+    const category = document.getElementById("namecoinCategory");
     const section = document.getElementById("namecoinSection");
-    if (!section) return;
+    if (!section || !category) {
+      return;
+    }
+
+    if (!shouldShow) {
+      // Keep both hidden -- the pref exists in about:config for power users.
+      category.hidden = true;
+      section.hidden = true;
+      return;
+    }
+
+    // Show the section.
+    category.hidden = false;
+    section.hidden = false;
+
+    // Record telemetry for feature visibility.
+    Services.telemetry.scalarSet(
+      "namecoin.settings_visible",
+      true
+    );
 
-    // Show the section (hidden by default in XHTML for graceful degradation)
-    section.hidden = false;
+    // Record telemetry when user toggles the enabled pref via the UI.
+    const enableCheckbox = document.getElementById("namecoinEnabled");
+    if (enableCheckbox) {
+      enableCheckbox.addEventListener("command", () => {
+        Services.telemetry.scalarAdd("namecoin.enabled_changed", 1);
+      });
+    }
 
     // Bind the enable checkbox to the pref
     const enableCheckbox = document.getElementById("namecoinEnabled");
 
diff --git a/toolkit/components/telemetry/Scalars.yaml b/toolkit/components/telemetry/Scalars.yaml
index 00000009..0000000a 100644
