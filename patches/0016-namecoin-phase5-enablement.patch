+# Merge into toolkit/components/telemetry/Scalars.yaml at the end of file.
+
+namecoin:
+  settings_visible:
+    bug_numbers:
+      - XXXXXX
+    description: >
+      Whether the Namecoin settings section is visible in Privacy & Security.
+      Set to true when Stage B (Beta+) is active or on Nightly builds.
+    expires: never
+    kind: boolean
+    notification_emails:
+      - necko@mozilla.com
+    release_channel_collection: opt-in
+    products:
+      - firefox
+
+  enabled_changed:
+    bug_numbers:
+      - XXXXXX
+    description: >
+      Incremented each time a user toggles network.namecoin.enabled via
+      the Settings UI. Used to measure Stage B engagement and adoption.
+      Does NOT fire for about:config changes -- only the Settings toggle.
+    expires: never
+    kind: uint
+    notification_emails:
+      - necko@mozilla.com
+    release_channel_collection: opt-in
+    products:
+      - firefox
