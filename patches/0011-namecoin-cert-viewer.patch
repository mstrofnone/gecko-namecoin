--- a/security/manager/ssl/TransportSecurityInfo.h
+++ b/security/manager/ssl/TransportSecurityInfo.h
@@ -15,6 +15,7 @@
 #include "nsITransportSecurityInfo.h"
 #include "nsString.h"
 #include "nsTArray.h"
+#include "mozilla/Maybe.h"
 
 namespace mozilla {
 namespace psm {
@@ -30,6 +31,13 @@ class TransportSecurityInfo : public nsI
 
   // ... existing members ...
 
+  // Namecoin DANE-TLSA validation result, populated by AuthCertificate
+  // when the host is a .bit domain. Read by the certificate viewer to
+  // display blockchain verification details.
+  struct NamecoinDANEInfo {
+    bool validated = false;
+    uint32_t blockHeight = 0;
+    nsCString txHash;           // 64-char hex SHA-256d of the NAME_UPDATE tx
+    uint32_t expiryBlock = 0;
+    uint8_t tlsaUsage = 0;     // 2 = DANE-TA, 3 = DANE-EE
+    uint8_t tlsaSelector = 0;  // 0 = Full cert, 1 = SPKI
+    uint8_t tlsaMatchType = 0; // 0 = Exact, 1 = SHA-256, 2 = SHA-512
+  };
+  Maybe<NamecoinDANEInfo> mNamecoinDANEInfo;
+
  private:
   // ... existing private members ...
 };
